           <property name="styleSheet">
            <string notr="true">/* 普通状态：透明、无边框、无图标 */
        QPushButton {
            background-color: transparent; /* 透明背景 */
            border: none; /* 无边框 */
            /* 普通状态下不显示图标 */
        }
        
        /* 鼠标悬停状态：显示图标 */
        QPushButton:hover {
            qproperty-icon: url(:/a/img/表情包.svg); /* 替换为你的图标路径 */
            qproperty-iconSize: 40px 40px; /* 图标大小 */
        }
        
        /* 可选：添加点击效果 */
        QPushButton:pressed {
            opacity: 0.8; /* 点击时稍微透明一点 */
        }</string>
           </property>
