           <property name="styleSheet">
            <string notr="true">QTextEdit {
        /* 浅灰色边框（#E0E0E0 为常用浅灰，可按需调整） */
        border: 1px solid #E0E0E0;
        /* 圆角半径（8px 适中，可根据需求增大/减小） */
        border-radius: 7px;
        /* 内边距（避免文字紧贴边框，提升美观度） */
        padding: 8px;
        /* 背景色（默认白色，可选透明 background: transparent;） */
        background-color: #FFFFFF;
        /* 字体（可选，统一界面风格） */
        font-size: 15px;
        font-family: &quot;Microsoft YaHei&quot;, sans-serif;
    }

    /* 聚焦状态（可选，增强交互反馈） */
    QTextEdit:focus {
        /* 聚焦时边框加深，突出当前控件 */
        border-color: #B0B0B0;
        /* 取消默认聚焦虚线（Qt 部分风格会有） */
        outline: none;
    }

    /* 禁用状态（可选，优化视觉体验） */
    QTextEdit:disabled {
        border-color: #F0F0F0;
        background-color: #F8F8F8;
        color: #A0A0A0;
    }</string>
           </property>
           <property name="frameShape">
            <enum>QFrame::Shape::NoFrame</enum>
           </property>
           <property name="frameShadow">
            <enum>QFrame::Shadow::Sunken</enum>
           </property>
           <property name="undoRedoEnabled">
