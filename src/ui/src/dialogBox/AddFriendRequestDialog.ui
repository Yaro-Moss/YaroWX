        <property name="styleSheet">
         <string notr="true">       QPushButton {
            border: none;
            background-color: transparent;
            border-top-right-radius: 7px;  
			margin: 0;
            text-align: center;
        }

        /* 鼠标悬停状态：红色背景 */
        QPushButton:hover {
  			 background-color: rgb(255, 65, 68); 
            border-top-right-radius: 7px;
            color: white; 
        }

        /* 鼠标点击状态：红色加深 */
        QPushButton:pressed {
            /* 可选：点击时轻微偏移，模拟按压效果 */
            padding-top: 1px;
            padding-left: 1px;
            border-top-right-radius: 7px;
            background-color: rgb(214, 55, 57);
        }
</string>
