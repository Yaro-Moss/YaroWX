              <property name="styleSheet">
               <string notr="true">QToolButton {
	font:  15pt &quot;华文琥珀&quot;;
    border: none; /* 无边框 */
/* 上下内边距相等，实现垂直居中 */
    padding-top: 0px;
    padding-bottom: 5px;
    background-color: transparent; /* 透明背景 */
    border-radius: 3px; /* 轻微圆角，可选 */
	color: rgb(108, 108, 108);
}

/* 鼠标悬停状态 */
QToolButton:hover {
    background-color:rgb(220, 220, 220); /* 灰色背景 */
}

/* 鼠标按下状态（可选增强） */
QToolButton:pressed {
    background-color: rgb(180, 180, 180); /* 按下时更深的灰色 */
}

/* 禁用状态（可选增强） */
QToolButton:disabled {
    background-color: transparent;
    color: rgb(160, 160, 160); /* 禁用时文本变灰 */
}
    </string>
