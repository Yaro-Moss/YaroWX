/* 基本样式：透明无边框 */
QToolButton {
    border: none;                 /* 去除边框 */
    background-color: transparent; /* 背景透明 */
    padding:4 px;                 /* 适当内边距，避免内容太贴边 */
    margin: 0px;                  /* 去除外边距 */
}

/* 鼠标悬浮时：灰色背景 */
QToolButton:hover {
    background-color: rgba(200, 200, 200, 100); /* 半透明灰色 */
    border-radius: 0px;           /* 轻微圆角，视觉更友好 */
}

/* 可选：按下状态样式 */
QToolButton:pressed {
    background-color: rgba(150, 150, 150, 150); /* 按下时更深的灰色 */
}</string>
